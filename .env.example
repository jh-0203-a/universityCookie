# ============================================================
# 환경변수 예시 파일.  실제 값은 .env 에 적으세요 (.env 는 git 에 안 올라갑니다)
#   - 로컬 개발: 아래 "로컬" 항목만 채우면 됩니다.
#   - 배포(Render 등): "배포" 항목을 호스팅 사이트의 환경변수 설정에 넣습니다.
# ============================================================

# ---------- 로컬 개발용 (내 PC PostgreSQL) ----------
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=여기에_로컬_DB_비밀번호
PGDATABASE=cookie_db
# 로컬에서 사진을 저장할 폴더 (없으면 자동 생성)
COOKIE_DB_DIR=D:\Cookie_db

# ---------- 배포용 (클라우드) ----------
# 서버 포트 (Render 등이 자동으로 넣어줍니다. 로컬에선 비워두면 4000)
# PORT=4000

# 클라우드 DB 연결문자열 (Supabase/Render 등이 제공). 이게 있으면 위 PG* 대신 이걸 씁니다.
# DATABASE_URL=postgresql://유저:비번@호스트:5432/DB이름

# 사진을 Supabase Storage 에 저장하려면 아래 3개를 모두 채우세요. (셋 다 있어야 클라우드 모드)
# SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_SERVICE_KEY=서비스_role_키(service_role, 비밀)
# SUPABASE_BUCKET=photos
